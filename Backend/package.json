{
  "name": "backend",
  "version": "1.0.0",
  "description": "Haramaya University Project Store Backend API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "NODE_ENV=test jest --watch --detectOpenHandles",
    "test:coverage": "NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "dev": "nodemon index.js",
    "start": "node index.js",
    "build": "echo 'No build step required for Node.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "setup-db": "node scripts/setup-database.js",
    "setup-local-db": "node scripts/setup-local-database.js",
    "setup-enhanced-db": "node scripts/setup-enhanced-database.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "tunnel:start": "bash scripts/ssh-tunnel.sh start || scripts\\ssh-tunnel.bat start",
    "tunnel:stop": "bash scripts/ssh-tunnel.sh stop || scripts\\ssh-tunnel.bat stop",
    "tunnel:status": "bash scripts/ssh-tunnel.sh status || scripts\\ssh-tunnel.bat status",
    "tunnel:restart": "bash scripts/ssh-tunnel.sh restart || scripts\\ssh-tunnel.bat restart",
    "docker:build": "docker build -t hups-backend .",
    "docker:run": "docker run -p 5000:5000 hups-backend",
    "security:audit": "npm audit --audit-level moderate",
    "security:fix": "npm audit fix"
  },
  "author": "Haramaya University",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.17.2",
    "validator": "^13.12.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
